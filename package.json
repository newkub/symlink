{
  "bin": {
    "wsymlink": "./dist/index.js"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0"
  },
  "description": "CLI tool for managing symlinks with composition pattern",
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@types/node": "^24.10.0",
    "tsdown": "^0.15.12",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "symlink",
    "cli",
    "composition",
    "node"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "name": "wymlink",
  "private": false,
  "scripts": {
    "build": "tsdown --exports --dts && bun link",
    "dev": "bun run --watch src/index.ts",
    "lint": "biome lint --write",
    "release": "release-it",
    "test": "vitest run"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "0.0.1"
}